{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@nextjs-tpl/db#build": {
      "outputs": []
    },
    "@nextjs-tpl/api-contract#build": {
      "outputs": []
    },
    "@nextjs-tpl/config#build": {
      "outputs": []
    },
    "@nextjs-tpl/ui#build": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
